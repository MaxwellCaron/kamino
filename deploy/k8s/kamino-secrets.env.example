# Copy this file outside the repository, replace every value, and create the
# kamino-secrets Secret as described in deploy/k8s/README.md.

DATABASE_URL=postgres://kamino:replace-me@postgres.example.internal:5432/kamino?sslmode=require
JWT_SECRET=replace-with-a-random-secret

PROXMOX_URL=https://proxmox.example.internal:8006
PROXMOX_TOKEN_ID=kamino@pve!kamino-token
PROXMOX_TOKEN_SECRET=replace-me
PROXMOX_NODES=node1,node2

# Production authentication requires PRINCIPAL_PROVIDER. Use active_directory
# with LDAP settings below, or proxmox with PROXMOX_AUTH_REALM and no LDAP vars.
PRINCIPAL_PROVIDER=active_directory
PRINCIPAL_BOOTSTRAP_ADMIN_GROUP=CN=KaminoAdmins,OU=Groups,DC=example,DC=internal

LDAP_URL=ldaps://dc.example.internal:636
LDAP_BIND_DN=CN=kamino,OU=ServiceAccounts,DC=example,DC=internal
LDAP_BIND_PASSWORD=replace-me
LDAP_SEARCH_BASE_DN=DC=example,DC=internal
LDAP_USER_OU=OU=Users,DC=example,DC=internal
LDAP_GROUP_OU=OU=Groups,DC=example,DC=internal
