{
  "name": "kamino",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "doctor:web": "bunx react-doctor@latest ./apps/web --scope changed --lint --verbose",
    "doctor:ui": "bunx react-doctor@latest ./packages/ui --scope changed --lint --verbose",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "test": "turbo test"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "web": "workspace:*"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@headless-tree/core": "^1.7.0",
    "@headless-tree/react": "^1.7.0",
    "@tanstack/react-table": "^8.21.3",
    "@unpic/react": "^1.0.2"
  }
}
