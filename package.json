{
  "name": "kamino",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "doctor:web": "bunx react-doctor@latest ./apps/web --scope changed --lint --verbose",
    "doctor:ui": "bunx react-doctor@latest ./packages/ui --scope changed --lint --verbose",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "typecheck:stable": "turbo typecheck:stable",
    "test": "turbo test"
  },
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@headless-tree/core": "^1.7.0",
    "@headless-tree/react": "^1.7.0",
    "@tanstack/react-table": "^8.21.3",
    "@unpic/react": "^1.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn": "^4.13.0",
    "turbo": "^2.10.4",
    "@typescript/native": "npm:typescript@^7.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "web": "workspace:*"
  },
  "overrides": {
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "@typescript-eslint/project-service": "8.63.0",
    "@typescript-eslint/scope-manager": "8.63.0",
    "@typescript-eslint/tsconfig-utils": "8.63.0",
    "@typescript-eslint/type-utils": "8.63.0",
    "@typescript-eslint/types": "8.63.0",
    "@typescript-eslint/typescript-estree": "8.63.0",
    "@typescript-eslint/utils": "8.63.0",
    "@typescript-eslint/visitor-keys": "8.63.0",
    "fast-uri": ">=3.1.2",
    "hono": ">=4.12.25",
    "typescript-eslint": "8.63.0"
  }
}
