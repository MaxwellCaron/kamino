# Copy to .env and fill in all required values before starting the API.
# Required vars are marked [required]; the rest have safe defaults shown here.

# --- Core (required) ---
DATABASE_URL=postgres://kamino:change-me@localhost:5432/kamino?sslmode=disable

# Generate with: openssl rand -base64 32
JWT_SECRET=change-me

# --- Proxmox (required) ---
PROXMOX_URL=https://proxmox.example.internal:8006
PROXMOX_TOKEN_ID=kamino@pve!kamino-token
PROXMOX_TOKEN_SECRET=change-me
# Comma-separated list of Proxmox node names
PROXMOX_NODES=node1,node2
# Set true only in isolated lab environments — never in production
PROXMOX_INSECURE=false

# --- Server (optional defaults shown) ---
PORT=:8080
FRONTEND_URL=http://localhost:3000

# --- Active Directory / LDAP (optional; all required if AD auth/sync is enabled) ---
LDAP_URL=ldaps://dc.example.internal:636
LDAP_BIND_DN=CN=kamino,OU=ServiceAccounts,DC=example,DC=internal
LDAP_BIND_PASSWORD=change-me
LDAP_SEARCH_BASE_DN=DC=example,DC=internal
LDAP_USER_OU=OU=Users,DC=example,DC=internal
LDAP_GROUP_OU=OU=Groups,DC=example,DC=internal
LDAP_ADMIN_GROUP_DN=CN=KaminoAdmins,OU=Groups,DC=example,DC=internal
# Set true only in isolated lab environments — never in production
LDAP_INSECURE=false

# --- Features (optional) ---
# Proxmox item ID of the router VM template used for pod cloning
POD_ROUTER_TEMPLATE_ITEM_ID=
