# Copy to .env and fill in all required values before starting the API.
# Required vars are marked [required]; the rest have safe defaults shown here.

# --- Core (required) ---
DATABASE_URL=postgres://kamino:change-me@localhost:5432/kamino?sslmode=disable
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me
# Server
PORT=:8080
FRONTEND_URL=http://localhost:3000
# Comma-separated CIDRs of reverse proxies allowed to set X-Forwarded-For
# TRUSTED_PROXY_CIDRS=10.0.0.0/8

# --- Proxmox (required) ---
PROXMOX_URL=https://proxmox.example.internal:8006
PROXMOX_TOKEN_ID=kamino@pve!kamino-token
PROXMOX_TOKEN_SECRET=change-me
# Comma-separated list of Proxmox node names
PROXMOX_NODES=node1,node2
# Optional client-reachable hostname or IP literal for native SPICE clients (TCP 3128).
# Defaults to the hostname from PROXMOX_URL when unset.
# PROXMOX_SPICE_PROXY_HOST=spice.clients.example
# Set true only in isolated lab environments — never in production
PROXMOX_INSECURE=false
# Set false to skip the startup Proxmox-to-database inventory import
PROXMOX_INITIAL_SYNC_ENABLED=true

# --- Principal provider (required) ---
# active_directory or proxmox
PRINCIPAL_PROVIDER=active_directory
# Set false to skip the startup principal sync for the selected provider
PRINCIPAL_INITIAL_SYNC_ENABLED=true
# Optional initial administrator group seed, interpreted by the selected provider:
# AD distinguished name in active_directory mode, Proxmox group ID in proxmox mode
PRINCIPAL_BOOTSTRAP_ADMIN_GROUP=CN=KaminoAdmins,OU=Groups,DC=example,DC=internal
# Proxmox principal provider settings (only when PRINCIPAL_PROVIDER=proxmox)
PROXMOX_AUTH_REALM=pve
# Defaults to PROXMOX_AUTH_REALM when unset
PROXMOX_MANAGED_USER_REALM=

# --- Active Directory / LDAP (required when PRINCIPAL_PROVIDER=active_directory) ---
LDAP_URL=ldaps://dc.example.internal:636
LDAP_BIND_DN=CN=kamino,OU=ServiceAccounts,DC=example,DC=internal
LDAP_BIND_PASSWORD=change-me
LDAP_SEARCH_BASE_DN=DC=example,DC=internal
LDAP_USER_OU=OU=Users,DC=example,DC=internal
LDAP_GROUP_OU=OU=Groups,DC=example,DC=internal
# Set true only in isolated lab environments — never in production
LDAP_INSECURE=false

# --- Inventory folder item IDs (optional) ---
# Pin the Templates library, Pods root, and Personal-Pods root folders by
# Proxmox item ID. When unset, name-based fallback is used.
TEMPLATES_FOLDER_ITEM_ID=
PODS_FOLDER_ITEM_ID=
PERSONAL_PODS_FOLDER_ITEM_ID=
# Proxmox item ID of the router VM template used for pod cloning
POD_ROUTER_TEMPLATE_ITEM_ID=

# --- VMID allocation ranges (optional; defaults shown; ranges must not overlap) ---
POD_PUBLISH_VMID_MIN=1000
POD_PUBLISH_VMID_MAX=1999
POD_CLONE_VMID_MIN=2000
POD_CLONE_VMID_MAX=9999
POD_DEV_VMID_MIN=10000
POD_DEV_VMID_MAX=19999
PERSONAL_POD_VMID_MIN=20000
PERSONAL_POD_VMID_MAX=20999

# --- VM concurrency (optional) ---
VM_OPERATION_CONCURRENCY=2
VM_POWER_CONCURRENCY=6
VM_POWER_TASK_TIMEOUT=5m

# --- Pod clone networking (optional defaults shown) ---
POD_CLONE_VNET_PREFIX=pod
POD_LAN_VLAN_BASE=0
POD_CLONE_NETWORK_MIN=1
POD_CLONE_NETWORK_MAX=174
POD_DEV_NETWORK_MIN=175
POD_DEV_NETWORK_MAX=199
POD_ROUTER_WAIT_TIMEOUT=5m
POD_ROUTER_WAN_IP_BASE=172.16.
POD_ROUTER_INTERNAL_SUBNET=192.168.1.0/24
POD_ROUTER_CLOUD_INIT_STORAGE=local
POD_ROUTER_CLOUD_INIT_USER_FILE_PATTERN=kamino-router-{network}-user-data.yaml
POD_ROUTER_CLOUD_INIT_NETWORK_FILE=kamino-router-network-config.yaml
POD_DMZ_VNET_PREFIX=dmz
POD_DMZ_VLAN_BASE=1000
POD_ROUTER_LAN_DMZ_CLOUD_INIT_USER_FILE_PATTERN=kamino-router-lan-dmz-{network}-user-data.yaml
POD_ROUTER_LAN_DMZ_CLOUD_INIT_NETWORK_FILE=kamino-router-lan-dmz-network-config.yaml

# --- Personal pods (optional) ---
PERSONAL_PODS_ENABLED=false
# Optional personal router template override. When blank, personal pods use
# POD_ROUTER_TEMPLATE_ITEM_ID.
PERSONAL_POD_ROUTER_TEMPLATE_ITEM_ID=
PERSONAL_POD_VNET_PREFIX=prsn
PERSONAL_POD_VLAN_BASE=4000
PERSONAL_POD_NETWORK_MIN=1
PERSONAL_POD_NETWORK_MAX=94
PERSONAL_POD_WAN_IP_BASE=172.25.
PERSONAL_POD_CLOUD_INIT_USER_FILE_PATTERN=kamino-personal-router-{network}-user-data.yaml
