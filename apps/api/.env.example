# Copy to .env and fill in all required values before starting the API.
# Required vars are marked [required]; the rest have safe defaults shown here.

# --- Core (required) ---
DATABASE_URL=postgres://kamino:change-me@localhost:5432/kamino?sslmode=disable
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me
# Server
PORT=:8080
FRONTEND_URL=http://localhost:3000

# --- Proxmox (required) ---
PROXMOX_URL=https://proxmox.example.internal:8006
PROXMOX_TOKEN_ID=kamino@pve!kamino-token
PROXMOX_TOKEN_SECRET=change-me
# Comma-separated list of Proxmox node names
PROXMOX_NODES=node1,node2
# Set true only in isolated lab environments — never in production
PROXMOX_INSECURE=false

# --- Active Directory / LDAP (optional; all required if AD auth/sync is enabled) ---
LDAP_URL=ldaps://dc.example.internal:636
LDAP_BIND_DN=CN=kamino,OU=ServiceAccounts,DC=example,DC=internal
LDAP_BIND_PASSWORD=change-me
LDAP_SEARCH_BASE_DN=DC=example,DC=internal
LDAP_USER_OU=OU=Users,DC=example,DC=internal
LDAP_GROUP_OU=OU=Groups,DC=example,DC=internal
LDAP_ADMIN_GROUP_DN=CN=KaminoAdmins,OU=Groups,DC=example,DC=internal
# Set true only in isolated lab environments — never in production
LDAP_INSECURE=false

# --- Inventory folder item IDs (optional) ---
# Pin the Templates library, Pods root, and Personal-Pods root folders by
# Proxmox item ID. When unset, name-based fallback is used.
TEMPLATES_FOLDER_ITEM_ID=
PODS_FOLDER_ITEM_ID=
PERSONAL_PODS_FOLDER_ITEM_ID=
# Proxmox item ID of the router VM template used for pod cloning
POD_ROUTER_TEMPLATE_ITEM_ID=

# --- Pod clone networking (optional defaults shown) ---
POD_CLONE_VNET_PREFIX=pod
POD_CLONE_NETWORK_MIN=1
POD_CLONE_NETWORK_MAX=174
POD_DEV_NETWORK_MIN=175
POD_DEV_NETWORK_MAX=199
POD_ROUTER_WAIT_TIMEOUT=5m
POD_ROUTER_WAN_IP_BASE=172.16.
POD_ROUTER_INTERNAL_SUBNET=192.168.1.0/24
POD_ROUTER_CLOUD_INIT_STORAGE=local
POD_ROUTER_CLOUD_INIT_USER_FILE_PATTERN=kamino-router-{network}-user-data.yaml
POD_ROUTER_CLOUD_INIT_NETWORK_FILE=kamino-router-network-config.yaml

# --- Personal pods (optional) ---
# Proxmox item ID of the router VM template cloned into each personal pod.
# Unset disables the feature.
PERSONAL_POD_ROUTER_TEMPLATE_ITEM_ID=
# Optional overrides; when blank these inherit POD_CLONE_VNET_PREFIX,
# POD_ROUTER_WAN_IP_BASE, and POD_ROUTER_CLOUD_INIT_USER_FILE_PATTERN.
PERSONAL_POD_VNET_PREFIX=
PERSONAL_POD_NETWORK_MIN=200
PERSONAL_POD_NETWORK_MAX=254
PERSONAL_POD_WAN_IP_BASE=
PERSONAL_POD_CLOUD_INIT_USER_FILE_PATTERN=
